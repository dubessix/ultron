# ─── IRIS AI — Ubuntu/Debian Linux Docker Build ───
# This Dockerfile builds the Electron app in a Linux container
# and packages it as an AppImage for Ubuntu/Debian systems.

FROM node:24-slim

# Install system dependencies required for Electron on Linux
RUN apt-get update && apt-get install -y \
    libnotify4 \
    libxtst6 \
    libnss3 \
    libxss1 \
    libasound2 \
    libgbm1 \
    libgtk-3-0 \
    wmctrl \
    xclip \
    xdotool \
    curl \
    xvfb \
    dbus \
    libdrm2 \
    libxkbcommon0 \
    libgbm-dev \
    libwayland-client0 \
    libwayland-server0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package*.json ./

RUN npm ci

COPY . .

# Build the Electron app for Linux
RUN npm run build && npx electron-builder --linux

# The built artifacts will be in /app/dist/
CMD ["ls", "-la", "/app/dist"]
